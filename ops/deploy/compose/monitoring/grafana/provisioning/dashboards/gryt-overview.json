{
  "uid": "gryt-overview",
  "title": "Gryt Overview",
  "tags": ["gryt"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Server Up",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [
        { "expr": "up{job=\"gryt-server\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "SFU Up",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [
        { "expr": "up{job=\"gryt-sfu\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Socket.IO Connections",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [
        { "expr": "gryt_socketio_connections_active", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "SFU Peers",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [
        { "expr": "gryt_sfu_peers_active", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "SFU Rooms",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [
        { "expr": "gryt_sfu_rooms_active", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Media Tracks",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [
        { "expr": "gryt_sfu_tracks_active", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "SFU WebSockets",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [
        { "expr": "gryt_sfu_websocket_connections_active", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate (by route)",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (route) (rate(gryt_http_requests_total{job=\"gryt-server\"}[5m]))",
          "legendFormat": "{{ route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "Request Duration (P50 / P95 / P99)",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gryt_http_request_duration_seconds_bucket{job=\"gryt-server\"}[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gryt_http_request_duration_seconds_bucket{job=\"gryt-server\"}[5m])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gryt_http_request_duration_seconds_bucket{job=\"gryt-server\"}[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (4xx / 5xx)",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(gryt_http_requests_total{job=\"gryt-server\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(gryt_http_requests_total{job=\"gryt-server\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "Request Rate (by status)",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (status) (rate(gryt_http_requests_total{job=\"gryt-server\"}[5m]))",
          "legendFormat": "{{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "type": "row",
      "title": "Server Process (Node.js)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Server Memory",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"gryt-server\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"gryt-server\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"gryt-server\"}",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "Server CPU",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"gryt-server\"}[5m])",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"gryt-server\"}",
          "legendFormat": "Lag"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"gryt-server\"}",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "type": "row",
      "title": "SFU Process (Go)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "SFU Memory",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"gryt-sfu\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "go_memstats_heap_alloc_bytes{job=\"gryt-sfu\"}",
          "legendFormat": "Heap Alloc"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"gryt-sfu\"}",
          "legendFormat": "Heap In-Use"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "SFU CPU",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"gryt-sfu\"}[5m])",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "SFU Goroutines",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "targets": [
        {
          "expr": "go_goroutines{job=\"gryt-sfu\"}",
          "legendFormat": "Goroutines"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ],
  "schemaVersion": 39
}
